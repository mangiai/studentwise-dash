# For the browser client (safe to expose in Vercel)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# For TanStack Start server functions / SSR
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the client or commit real values
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Deploy-time only (Vercel + GitHub Actions) — auto-runs `supabase db push` on deploy
# SUPABASE_ACCESS_TOKEN=your-supabase-access-token
# SUPABASE_DB_PASSWORD=your-database-password
# SUPABASE_PROJECT_REF=your-project-ref
